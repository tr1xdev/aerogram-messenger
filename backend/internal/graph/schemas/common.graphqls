scalar Long
scalar Upload

interface Node {
    id: ID!
}

interface Error {
    message: String!
}

type InternalError implements Error {
    message: String!
}

type ForbiddenError implements Error {
    message: String!
}

type NotFoundError implements Error {
    message: String!
}

type ValidationError implements Error {
    message: String!
    field: String
}

type SuccessResult {
    success: Boolean!
}
