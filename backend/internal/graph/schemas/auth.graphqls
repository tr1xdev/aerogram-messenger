type AuthPayload {
   userId: String
}

type VerifyEmailPayload {
   accessToken: String!
   refreshToken: String!
}

type Session {
   id: ID!
   device: String
   ipAddress: String
   location: String
   isActive: Boolean
   isCurrent: Boolean!
   createdAt: String!
}

input SignUpInput {
   username: String
   email: String!
   password: String!
   firstName: String!
   lastName: String
}

input LoginInput {
   email: String!
   password: String!
}

input VerifyEmailInput {
   userID: ID!
   code: String!
}

extend type Query {
   sessions(userId: ID!): [Session!]!
}

extend type Mutation {
   signUp(input: SignUpInput!): AuthPayload!
   login(input: LoginInput!): AuthPayload!
   verifyEmail(input: VerifyEmailInput!): VerifyEmailPayload!
   refreshToken(token: String!): VerifyEmailPayload!
   terminateAllOtherSessions: Boolean!
   terminateSession(id: ID!): Boolean!
   logout: Boolean!
}
