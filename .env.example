# --- CORE APP SETTINGS ---
APP_ENV=development               # development, production, test
APP_DEBUG=true                    # Enable detailed logs
TEST_EMAIL=email@example.com      # Redirect target for dev emails

# --- NETWORK & SERVER ---
HTTP_PORT=8080                    # REST/GraphQL port
GRPC_PORT=50051                   # gRPC port

# --- DATABASE: POSTGRESQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aerogram_db
DB_USER=admin
DB_PASSWORD=admin                 # CHANGE IN PRODUCTION
DB_SSL=disable                    # disable, require, verify-full

# --- DATABASE: REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redissecret        # For auth & rate-limiting
REDIS_DB=0

# --- STORAGE: S3 / MINIO ---
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET_NAME=aerogram-media
S3_PUBLIC_HOST=https://localhost:8443
S3_REGION=us-east-1
# S3_ENDPOINT=localhost:9000      # Uncomment for custom S3/MinIO
# S3_USE_SSL=false

# --- SECURITY & AUTH ---
JWT_SECRET=jwt_secret_key         # Token signing key
JWT_TTL=60                        # Minutes
RESEND_TOKEN=resend_api_token     # Resend (mailing service) API key

# --- 2FA ---
ENABLE_2FA=true
2FA_ON_SIGN_UP=true
2FA_ON_SIGN_IN=false
# 2FA_CODE_TTL=5m

# --- RATE LIMITS & QUOTAS ---
# LIMIT_GLOBAL_RPS=100
# CHAT_CREATE_LIMIT=10
# MAX_BOTS_PER_USER=10

# --- FRONTEND (VITE) ---
VITE_API_URL=http://localhost:8080/query
VITE_WS_URL=ws://localhost:8080/query
