# --- App Configuration ---
APP_ENV=development                               # Application mode: development, production
TEST_EMAIL=email@example.com                      # Email for dev mode redirects/testing
APP_DEBUG=true                                    # Enable verbose logging and debug tools

# --- Server & Network ---
HTTP_PORT=8080                                    # HTTP server port
GRPC_PORT=50051                                   # gRPC server port

# --- Database: PostgreSQL ---
DB_HOST=localhost                                 # PostgreSQL host
DB_PORT=5432                                      # PostgreSQL port
DB_NAME=aerogram_db                               # Database name
DB_USER=admin                                     # Database user
DB_PASSWORD=admin                                 # Database password (change in .env)
DB_SSL=disable                                    # SSL mode: disable, require, verify-full

# --- Database: Redis ---
REDIS_HOST=localhost                              # Redis host
REDIS_PORT=6379                                   # Redis port
REDIS_DB=0                                        # Redis database index (0-15)
REDIS_PASSWORD=redissecret                        # Redis password for auth/rate-limiting

# --- Auth & JWT ---
JWT_SECRET=jwt_secret_key                         # Secret key for signing access tokens
JWT_TTL=60                                        # Access token lifetime in minutes
RESEND_TOKEN=resend_api_token                     # API token for Resend mailing service

# --- 2FA Logic ---
ENABLE_2FA=true                                   # Master flag for 2FA availability
2FA_ON_SIGN_UP=true                               # Trigger 2FA during registration
2FA_ON_SIGN_IN=false                              # Trigger 2FA during login

# --- Rate Limiting (Optional Overrides) ---
LIMIT_GLOBAL_RPS=100                              # Global requests per second
LIMIT_GLOBAL_BURST=200                            # Global maximum burst size

# --- Rate Limiting (Chat Service) ---
CHAT_CREATE_LIMIT=10                              # Max number of chats a user can create in a 10m window
CHAT_DELETE_LIMIT=5                               # Max number of chats a user can delete in a 5m window

# --- Frontend Connections (Vite) ---
# Pointing to Nginx (3443) for SSL/Proxying
VITE_API_URL=https://localhost:3443/query
VITE_WS_URL=wss://localhost:3443/query

# S3
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET_NAME=aerogram-media
